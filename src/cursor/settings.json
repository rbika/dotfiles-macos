      "editor.lineHighlightBackground": "#f5f5f6",
      "editor.selectionBackground": "#f5f5f6",
      "minimap.selectionHighlight": "#00ff00",
      "peekViewResult.background": "#f5f5f6",
      "peekViewTitle.background": "#f5f5f6",
      "titleBar.activeBackground": "#f5f5f6",
      "statusBar.background": "#f5f5f6",
      "statusBar.debuggingBackground": "#f5f5f6",
      "statusBar.noFolderBackground": "#f5f5f6",
