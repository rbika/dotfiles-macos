[user]
	name = Rafael Bicalho
	email = rbmbika@gmail.com
    # Run "git config user.email <new-email>" inside a project to override the email config

[init]
    defaultBranch = main

[core]
    editor = nvim
    pager = less -FX

[push]
    default = current

[color]
    diff = auto
    status = auto
    branch = auto

[pretty]
    detailed = %C(green)%h%C(auto)%d %C(reset)%s %C(reset)%C(green)(%cr) %C(reset)%C(blue)%an %C(reset)
    no-branch-names = %C(green)%h %C(reset)%s %C(blue)%an %C(reset)

[alias]
    s = status
    b = branch --verbose
    d = diff
    a = add .
    p = "!git pull origin $(git rev-parse --abbrev-ref HEAD)"
    m = merge
    c = commit
    f = fetch -p
    co = checkout
    rb = rebase
    ch = cherry-pick
    cm = commit -m
    pr = !"open $(git repo-url)/pull/new/$(git branch --show-current)"
    wip = commit --no-verify -m "WIP"
    amend = commit --amend --no-edit
    unstage = reset HEAD
    uncommit = reset HEAD^
    open = !"open $(git repo-url)"
    # git compare source-branch..target-branch
    # shows commits from source-branch to target-branch
    compare = log --no-merges --pretty=no-branch-name
    alias = config --get-regexp alias

    l = log --graph --pretty=detailed --decorate-refs-exclude="tags/*" -5
    lf = log --graph --pretty=detailed --all

    # Internal aliases
    repo-url = "!git config remote.origin.url | sed -E 's/:([^\\/])/\\/\\1/g' | sed -e 's/git@/https:\\/\\//' | sed -e 's/\\.git$//'"
